# AWS Cognito (required for admin login)
VITE_COGNITO_REGION=us-east-1
VITE_COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
VITE_COGNITO_CLIENT_ID=your_app_client_id

# Contact form — Web3Forms (FREE)
# Sign up at https://web3forms.com with the inbox that should receive submissions.
# The access key is safe in the browser; restrict domains in the Web3Forms dashboard.
VITE_WEB3FORMS_ACCESS_KEY=your_access_key_here

# Optional server-side email (Resend/SMTP) if you prefer not to use Web3Forms
# WEB3FORMS_ACCESS_KEY=your_access_key_here
